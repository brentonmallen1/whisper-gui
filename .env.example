# ════════════════════════════════════════════════════════════════════════
#  Whisper GUI — Configuration
#  Copy this file to .env and edit as needed.
#  docker compose will read .env automatically.
# ════════════════════════════════════════════════════════════════════════

# ── Web App ─────────────────────────────────────────────────────────────
# Port exposed on the host machine. Access the UI at http://localhost:<PORT>
APP_PORT=8880


# ── Authentication ──────────────────────────────────────────────────────
# Enable HTTP Basic Auth for all endpoints. Set to true if exposing to network.
# When enabled, browser will prompt for username/password on first visit.
AUTH_ENABLED=false

# Credentials for HTTP Basic Auth (only used when AUTH_ENABLED=true).
# IMPORTANT: Change these from defaults if enabling auth!
AUTH_USERNAME=admin
AUTH_PASSWORD=

# ── Upload Limits ───────────────────────────────────────────────────────
# Maximum upload file size in MB. Set to 0 for unlimited.
MAX_UPLOAD_SIZE_MB=500


# ── Transcription Engine ────────────────────────────────────────────────
# Which engine to use for transcription.
# Options:
#   whisper        — OpenAI Whisper (CPU or GPU, pure Python)
#   faster-whisper — Faster-Whisper via CTranslate2 (CPU or GPU, ~4x faster than whisper)
#   canary         — NVIDIA NeMo Canary (GPU only, requires ENABLE_GPU=true)
#   qwen-audio     — Qwen2.5-Audio (GPU only, requires ENABLE_GPU=true)
TRANSCRIPTION_ENGINE=faster-whisper


# ── Whisper / Faster-Whisper Model Size ─────────────────────────────────
# Applies when TRANSCRIPTION_ENGINE is "whisper" or "faster-whisper".
# Options (smallest → largest, fastest → most accurate):
#   tiny           — ~39M params,  ~1 GB VRAM  — very fast, lower accuracy
#   base           — ~74M params,  ~1 GB VRAM
#   small          — ~244M params, ~2 GB VRAM  — good CPU option
#   medium         — ~769M params, ~5 GB VRAM
#   large          — ~1.5B params, ~10 GB VRAM
#   large-v2       — improved large
#   large-v3       — best accuracy
#   large-v3-turbo — ~809M params, ~6 GB VRAM, ~8x faster than large-v3 with minimal
#                    quality loss (decoder pruned from 32 → 4 layers). Recommended for GPU.
WHISPER_MODEL_SIZE=small


# ── Canary Model (engine=canary) ─────────────────────────────────────────
# Both models require ENABLE_GPU=true.
# Options:
#   nvidia/canary-qwen-2.5b — 2.5B params, FastConformer + Qwen3 LLM backbone,
#                             ~6 GB VRAM, #1 on OpenASR leaderboard (English only,
#                             with punctuation & capitalization). Requires NeMo git trunk.
#   nvidia/canary-1b        — 1B params, classic EncDecMultiTaskModel,
#                             English/Spanish/French/German, requires stable nemo_toolkit.
CANARY_MODEL=nvidia/canary-qwen-2.5b


# ── Qwen Audio Model (engine=qwen-audio) ─────────────────────────────────
# Options:
#   Qwen/Qwen2.5-Audio-3B-Instruct — 3B, ~8 GB VRAM (default, good balance)
#   Qwen/Qwen2.5-Audio-7B-Instruct — 7B, ~16 GB VRAM (higher quality if VRAM allows)
#   Qwen/Qwen2-Audio-7B-Instruct   — original 7B variant
QWEN_MODEL=Qwen/Qwen2.5-Audio-3B-Instruct


# ── GPU ─────────────────────────────────────────────────────────────────
# Set to true to expose your NVIDIA GPU to the container.
# Requires the nvidia-container-toolkit to be installed on the host:
#   https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html
# Set to false for CPU-only inference (canary and qwen-audio will not be available).
ENABLE_GPU=false

# Which GPUs to expose. Only used when ENABLE_GPU=true.
# Options:
#   all           — expose all available GPUs
#   0             — first GPU only
#   0,1           — first two GPUs
NVIDIA_VISIBLE_DEVICES=all


# ── Compute Type (faster-whisper only) ──────────────────────────────────
# CTranslate2 quantization. Affects speed vs. accuracy tradeoff.
# Options:
#   int8           — fastest, lowest memory, slight accuracy loss (good for CPU)
#   int8_float16   — int8 weights with float16 compute (good balance on GPU)
#   float16        — full float16 (best accuracy on GPU, requires ~2x VRAM)
#   float32        — full precision (slowest, most memory, rarely needed)
COMPUTE_TYPE=int8


# ── Language ─────────────────────────────────────────────────────────────
# Force a specific language for transcription (skips language auto-detection).
# Use ISO 639-1 codes. Leave blank to auto-detect.
# Options (common): en, es, fr, de, it, pt, ja, zh, ko, nl, pl, ru, ar, hi
# Note: Canary supports en, es, fr, de only.
# Recommended: keep "en" for English-only use — it's faster and more accurate.
LANGUAGE=en


# ── Volumes ───────────────────────────────────────────────────────────────
# Host path where downloaded model weights are stored.
# Models are large (1–15 GB each). Use a persistent location.
MODELS_VOLUME=./volumes/models

# Host path where uploaded audio files are temporarily cached.
AUDIO_CACHE_VOLUME=./volumes/audio_cache

# How long (in hours) to keep cached audio files before auto-purging.
# Set to 0 to disable auto-purge entirely.
AUDIO_CACHE_TTL_HOURS=72
